# Required on Vercel (Production / Preview). Used when someone enters the access code.
BAATCHEET_ACCESS_CODE=

# Required. At least 32 characters. Used to sign the session cookie (generate a random string).
BAATCHEET_SESSION_SECRET=

# Sanity (same project as the studio in ../baatcheet). Public read for published content.
NEXT_PUBLIC_SANITY_PROJECT_ID=fxy8dhsm
NEXT_PUBLIC_SANITY_DATASET=production
